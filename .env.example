# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MongoDB Atlas connection string)
MONGO_URI=mongodb://localhost:27017/ai-study-assistant

# Google Gemini AI API Configuration
GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY

# Cloudinary Cloud Asset Storage Configuration
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# Firebase Authentication Admin SDK Configuration
# This should contain the JSON string of your Firebase service account key
# Example: {"type": "service_account", "project_id": "...", "private_key_id": "...", ...}
FIREBASE_SERVICE_ACCOUNT_JSON=
